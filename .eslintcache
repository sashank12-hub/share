.log(location.id);\r\n       \r\n    return (\r\n        \r\n        <>\r\n        <Header/>\r\n        <div className=\"details\">\r\n    <div className=\"image1\">\r\n    <img src={\"\"}/>\r\n    </div>\r\n    <div className=\"body\">\r\n    <h2>Title:{location.id.title}</h2>\r\n    <p>ID : {location.id.bookID}</p>\r\n    <p>PRICE :Rs.{location.id.price}  </p>\r\n    <p>AUTHOR : {location.id.authors}</p>\r\n    <p>Reviwers : {location.id.ratings_count}</p> \r\n    <p>Rating : {location.id.average_rating}</p>     \r\n    <div> <button className=\"btn btn-primary\" onClick={()=>\r\n        addProductToCart(location)}>ADD TO CART</button>\r\n    </div>\r\n    \r\n    </div>\r\n\r\n\r\n    \r\n\r\n</div></>\r\n);\r\n    }\r\n}\r\nconst mapDispatchToProps=(dispatch)=>({\r\n    addProductToCart:(location)=>dispatch(add(location.id))\r\n})\r\nexport default connect(null,mapDispatchToProps) (Details);\r\n",["69","70"],"Q:\\react\\ecs\\src\\first.js",["71","72","73","74","75","76","77","78","79","80","81"],"Q:\\react\\ecs\\src\\App.js",["82","83","84","85","86","87","88","89","90"],"Q:\\react\\ecs\\src\\index.js",[],["91","92"],"Q:\\react\\ecs\\src\\store.js",[],"Q:\\react\\ecs\\src\\Books.js",[],"Q:\\react\\ecs\\src\\Header.js",["93","94","95","96","97"],"Q:\\react\\ecs\\src\\type.js",[],"Q:\\react\\ecs\\src\\productreducer.js",[],["98","99"],"Q:\\react\\ecs\\src\\search.js",["100","101","102","103","104"],"import axios from 'axios';\r\nimport React, { Component,useEffect,useState } from 'react';\r\nimport {BrowserRouter, Link, Route, Switch} from \"react-router-dom\";\r\nimport Header from './Header'\r\n\r\n\r\nfunction Search() {\r\nconst [data,setdata]=useState([])\r\nconst [load,setload]=useState(true);\r\nconst [search,setsearch]=useState(\"\");\r\n    useEffect(() => {\r\n        axios.get(\"https://s3-ap-southeast-1.amazonaws.com/he-public-data/books8f8fe52.json\").then(\r\n            res=>{\r\n                setdata(res.data);\r\n                setload(false);\r\n                \r\n            }\r\n        )\r\n        \r\n    }, [])\r\n    return ( <>\r\n        <Header/>\r\n        <input className=\"input\" type=\"text\" placeholder=\"...search by Title\" onKeyPress={(e)=>{\r\n           if( e.key === 'Enter'){\r\n           setsearch(e.target.value.toUpperCase());\r\n            console.log(e.target.value.toUpperCase())}\r\n        }}\r\n        \r\n        />\r\n       { load ? <h1>...Loading</h1>:\r\n           \r\n           <table className=\"table1\">\r\n        <thead>\r\n        <tr>\r\n        \r\n        <th >BookID</th>\r\n        <th >authors</th>\r\n        <th>INFO</th>\r\n        <th  >Price</th>\r\n        <th >Title</th>\r\n      <th >rating</th>\r\n        </tr>\r\n        </thead>\r\n        <tbody>\r\n        {   \r\n            data.filter((item)=>{\r\n                \r\n                  if(search===\"\") {\r\n                      return item\r\n                    }\r\n                 \r\n                  else if (item.title.toString().toUpperCase().includes(search))\r\n                 \r\n                //   else if((item.title).indexOf(search) > -1)\r\n                  {\r\n                      return item;\r\n                    \r\n                  }\r\n             }\r\n\r\n\r\n\r\n             )\r\n            .map((item,i)=>{ console.log(item.title);\r\n                return(\r\n             \r\n              \r\n                    <tr className=\"TableRow\">\r\n                    <td className={\"SecondaryText\"}>{item.bookID}</td> <td className={\"PrimaryText\"}>{(item.authors).slice(0,20)}</td>\r\n                    \r\n                    <td><Link to ={{\r\n                        pathname: `/ecs/details/:${item.bookID}`,\r\n                        id:item}}>CLICK HERE</Link></td>\r\n                      \r\n                       <td className={\"SecondaryText\"}>{item.price}</td>\r\n                       <td className={\"PrimaryText\"}>{(item.title)}</td>\r\n                       <td className={\"SecondaryText\"}>{item.average_rating}</td>\r\n                    \r\n                    \r\n                    </tr>)\r\n        \r\n            })\r\n        }\r\n        \r\n        </tbody>\r\n      </table>}\r\n\r\n\r\n        </>\r\n\r\n     );\r\n}\r\n \r\nexport default Search;","Q:\\react\\ecs\\src\\Pagination.js",[],"Q:\\react\\ecs\\src\\Checkout.js",["105","106","107","108","109","110"],"import React, { Component } from 'react';\r\nimport { connect } from 'react-redux';\r\nimport Checkoutcard from './checkoutcard';\r\nimport {BrowserRouter, Link, Route, Switch} from \"react-router-dom\";\r\nimport Header from './Header';\r\n\r\nclass Checkout extends Component {\r\n    constructor(props) {\r\n        super(props);\r\n        this.state = {  }\r\n    }\r\n    render() { let{count,checkproducts,total}=this.props;\r\n        return ( \r\n            \r\n            <>\r\n            <Header/>\r\n            \r\n            {count==0 && <div className=\"checkout1\">\r\n               \r\n               \r\n            <h1>ADD MORE PRODUCTS</h1>\r\n            </div>\r\n           \r\n        } \r\n        \r\n        {\r\n        count!==0 &&  (\r\n            <div className=\"checkout\">\r\n            {\r\n                checkproducts?.map(item=>{console.log(item)\r\n                return <Checkoutcard  item={item}/> })} </div>\r\n        )\r\n        \r\n                }\r\n            \r\n            </>\r\n            \r\n             );\r\n    }\r\n}\r\n \r\nconst mapStatetoProps = (store) => ({\r\n    count:store?.cart.length,\r\n    checkproducts:store?.cart,\r\n  total:  store?.cart?.reduce((amount,item)=>item.price+amount,0)\r\n    \r\n    \r\n})\r\n\r\n\r\nexport default connect(mapStatetoProps,null)(Checkout)\r\n\r\n","Q:\\react\\ecs\\src\\reportWebVitals.js",[],"Q:\\react\\ecs\\src\\Actions.js",[],{"ruleId":"111","severity":1,"message":"112","line":20,"column":5,"nodeType":"113","endLine":20,"endColumn":20},{